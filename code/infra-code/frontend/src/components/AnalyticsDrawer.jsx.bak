import React, { useEffect, useState, useMemo } from "react";
import { useNavigate } from "react-router-dom";
import { X, Search, Download, Cpu, HardDrive, Database, Server, Users, Monitor, ShieldAlert } from "lucide-react";
import proxmoxApi from "../api/proxmoxapi";
import ReportPopup from "./ReportPopup";
import Loader from "./Loader";

// Import motion from framer-motion explicitly
import { motion as dMotion, AnimatePresence as dAnimatePresence } from "framer-motion";

const formatGB = (gb) => {
  if (gb === null || gb === undefined) return "0 GB";
  const val = Number(gb);
  if (val >= 1024) {
    return `${(val / 1024).toFixed(2)} TB`;
  }
  return `${val.toFixed(1)} GB`;
};

const ALL_REPORT_FIELDS = [
  { key: "vm_name",              label: "VM Name" },
  { key: "vm_uuid",              label: "UUID" },
  { key: "os",                   label: "OS" },
  { key: "status",               label: "Status" },
  { key: "cpus",                 label: "CPUs" },
  { key: "max_memory",           label: "RAM (GB)" },
  { key: "max_disk",             label: "Disk (GB)" },
  { key: "cluster_name",         label: "Cluster" },
  { key: "node_name",            label: "Node" },
  { key: "ip",                   label: "IP Address" },
  { key: "mac",                  label: "MAC Address" },
  { key: "gpu",                  label: "GPU" },
  { key: "uptime",               label: "Uptime" },
  { key: "created_date",         label: "Created Date" },
];

export default function AnalyticsDrawer({
  isOpen,
  onClose,
  title = "Details",
  type = "vm", // vm, node, cluster, storage, user, ownership
  records = [],
  allVms = [], // used to compile aggregated VM metrics for nodes, clusters, etc.
}) {
  const navigate = useNavigate();
  const [searchQuery, setSearchQuery] = useState("");
  const [showPopup, setShowPopup] = useState(false);
  const [selectedColumns, setSelectedColumns] = useState(["vm_name", "os", "status", "cpus", "max_memory", "max_disk"]);
  const [selectedFormat, setSelectedFormat] = useState("csv");
  const [exporting, setExporting] = useState(false);

  useEffect(() => {
    if (isOpen) {
      setSearchQuery("");
    }
  }, [isOpen]);

  // Find VMs associated with the current list of records
  const associatedVms = useMemo(() => {
    if (type === "vm" || type === "ownership") {
      return records;
    }
    if (type === "node") {
      const nodeNames = new Set(records.map(r => (r.node_name || "").toLowerCase()));
      return allVms.filter(v => nodeNames.has((v.node_name || v.node || "").toLowerCase()));
    }
    if (type === "cluster") {
      const clusterNames = new Set(records.map(r => (r.cluster_name || "").toLowerCase()));
      return allVms.filter(v => clusterNames.has((v.cluster_name || v.cluster || "").toLowerCase()));
    }
    if (type === "storage") {
      // Map VMs using the listed storage pools
      const storageNames = new Set(records.map(r => (r.storage_name || "").toLowerCase()));
      return allVms.filter(v => {
        const storages = v.storages || [];
        return storages.some(s => storageNames.has((s.storage_name || "").toLowerCase()));
      });
    }
    if (type === "user" || type === "ownership") {
      const staffCodes = new Set(records.map(r => (r.staff_code || "").toLowerCase()));
      return allVms.filter(v => {
        const users = v.users || [];
        return users.some(u => staffCodes.has((u.staff_code || "").toLowerCase()));
      });
    }
    return [];
  }, [type, records, allVms]);

  // Aggregate Metrics derived from the associated VMs
  const aggregates = useMemo(() => {
    const totalCount = associatedVms.length;
    const runningCount = associatedVms.filter(v => (v.status || "").toLowerCase() === "running").length;
    
    // CPU Cores: check different property names 'cpus', 'cores', 'vm_cpu'
    const totalCpu = associatedVms.reduce((sum, v) => sum + (Number(v.cpus || v.cores || v.vm_cpu) || 0), 0);
    
    // RAM: check 'max_memory', 'ram', 'vm_max_mem' (in GB or bytes, typical database representation is GB, backend represents MB/GB. Let's align)
    const totalRam = associatedVms.reduce((sum, v) => sum + (Number(v.max_memory || v.ram || v.vm_max_mem) || 0), 0);
    
    // Storage: check 'max_disk', 'disk_size', 'vm_max_disk'
    const totalDisk = associatedVms.reduce((sum, v) => sum + (Number(v.max_disk || v.disk_size || v.vm_max_disk) || 0), 0);

    return { totalCount, runningCount, totalCpu, totalRam, totalDisk };
  }, [associatedVms]);

  // Filter records based on in-drawer local search
  const filteredRecords = useMemo(() => {
    if (!searchQuery) return records;
    const query = searchQuery.toLowerCase().trim();
    return records.filter(r => {
      // Check multiple possible key string properties
      return Object.values(r).some(val => 
        val !== null && val !== undefined && String(val).toLowerCase().includes(query)
      );
    });
  }, [records, searchQuery]);

  // Export handler for VMs
  const handleExport = async () => {
    const uuids = associatedVms.map(v => v.vm_uuid || v.uuid).filter(Boolean);
    if (!uuids.length) {
      alert("No matching VM records found to export.");
      return;
    }
    try {
      setExporting(true);
      const res = await proxmoxApi.post(
        "/proxmox/report",
        { columns: selectedColumns, format: selectedFormat, uuids },
        { responseType: selectedFormat === "json" ? "json" : "blob" }
      );
      if (selectedFormat === "pdf") {
        const html = typeof res.data === "string" ? res.data : await res.data.text();
        const win = window.open("", "_blank");
        win.document.write(html);
        win.document.close();
      } else {
        const blob = res.data instanceof Blob ? res.data : new Blob([res.data]);
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `drawer-report.${selectedFormat}`;
        a.click();
        URL.revokeObjectURL(url);
      }
      setShowPopup(false);
    } catch (err) {
      console.error("Export failed inside drawer:", err);
      alert("Failed to export. Please try again.");
    } finally {
      setExporting(false);
    }
  };

  if (!isOpen) return null;

  return (
    <dAnimatePresence>
      {/* Backdrop */}
      <dMotion.div
        className="drawer-overlay"
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        onClick={onClose}
      />

      {/* Sliding Drawer container */}
      <dMotion.div
        className="drawer-container text-slate-800 dark:text-slate-100 flex flex-col h-full bg-white dark:bg-slate-900 border-l border-slate-200 dark:border-slate-800"
        initial={{ x: "100%" }}
        animate={{ x: 0 }}
        exit={{ x: "100%" }}
        transition={{ type: "tween", duration: 0.3 }}
      >
        {/* Header */}
        <div className="p-5 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between bg-slate-50 dark:bg-slate-900/60 shrink-0">
          <div>
            <h2 className="text-lg font-bold tracking-tight text-slate-900 dark:text-white">{title}</h2>
            <p className="text-xs text-slate-400 mt-0.5">Showing {filteredRecords.length} records</p>
          </div>
          <div className="flex items-center gap-2">
            {associatedVms.length > 0 && (
              <button
                onClick={() => setShowPopup(true)}
                className="p-1.5 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition"
                title="Export matching VMs report"
              >
                <Download size={18} />
              </button>
            )}
            <button
              onClick={onClose}
              className="p-1.5 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 transition"
            >
              <X size={18} />
            </button>
          </div>
        </div>

        {/* Aggregated Resources Summary (Change 7) */}
        {associatedVms.length > 0 && (
          <div className="p-4 bg-slate-50/50 dark:bg-slate-950/20 border-b border-slate-150 dark:border-slate-800/80 grid grid-cols-4 gap-2 text-center shrink-0">
            <div className="p-2 bg-white dark:bg-slate-900 rounded-xl border border-slate-200/60 dark:border-slate-800/40">
              <span className="block text-[10px] text-slate-400 font-bold uppercase tracking-wider">VMs</span>
              <span className="text-sm font-bold text-slate-800 dark:text-slate-150">{aggregates.totalCount} ({aggregates.runningCount} run)</span>
            </div>
            <div className="p-2 bg-white dark:bg-slate-900 rounded-xl border border-slate-200/60 dark:border-slate-800/40">
              <span className="block text-[10px] text-slate-400 font-bold uppercase tracking-wider flex items-center justify-center gap-0.5"><Cpu size={10} /> CPU</span>
              <span className="text-sm font-bold text-slate-800 dark:text-slate-150">{aggregates.totalCpu} Cores</span>
            </div>
            <div className="p-2 bg-white dark:bg-slate-900 rounded-xl border border-slate-200/60 dark:border-slate-800/40">
              <span className="block text-[10px] text-slate-400 font-bold uppercase tracking-wider flex items-center justify-center gap-0.5"><HardDrive size={10} /> RAM</span>
              <span className="text-sm font-bold text-slate-800 dark:text-slate-150">{formatGB(aggregates.totalRam)}</span>
            </div>
            <div className="p-2 bg-white dark:bg-slate-900 rounded-xl border border-slate-200/60 dark:border-slate-800/40">
              <span className="block text-[10px] text-slate-400 font-bold uppercase tracking-wider flex items-center justify-center gap-0.5"><Database size={10} /> Disk</span>
              <span className="text-sm font-bold text-slate-800 dark:text-slate-150">{formatGB(aggregates.totalDisk)}</span>
            </div>
          </div>
        )}

        {/* Local Search input (Change 4) */}
        <div className="p-4 border-b border-slate-100 dark:border-slate-800 flex gap-2 shrink-0">
          <div className="relative flex-1">
            <Search className="absolute left-3 top-2.5 text-slate-400" size={16} />
            <input
              type="text"
              placeholder="Search records in drawer..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="w-full pl-9 pr-4 py-2 text-xs rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-800 dark:text-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>
        </div>

        {/* Drawer Table/List content */}
        <div className="flex-1 overflow-y-auto p-4">
          {filteredRecords.length === 0 ? (
            <div className="text-center py-12 text-slate-500">
              <ShieldAlert className="mx-auto text-slate-300 dark:text-slate-700 mb-2" size={32} />
              <p className="text-xs">No matching records found.</p>
            </div>
          ) : (
            <div className="overflow-x-auto border border-slate-100 dark:border-slate-800/60 rounded-xl">
              <table className="w-full text-xs text-left">
                {/* VM Table Header */}
                {(type === "vm" || type === "ownership") && (
                  <>
                    <thead className="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 uppercase tracking-wider font-bold">
                      <tr>
                        <th className="px-3 py-2.5">Name</th>
                        <th className="px-3 py-2.5">Status</th>
                        <th className="px-3 py-2.5">OS</th>
                        <th className="px-3 py-2.5">Cores/RAM/Disk</th>
                        <th className="px-3 py-2.5">Node/Cluster</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100 dark:divide-slate-800">
                      {filteredRecords.map((vm, idx) => (
                        <tr key={vm.vm_uuid || idx} className="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                          <td className="px-3 py-2 font-mono font-bold">
                            <button
                              onClick={() => {
                                navigate(`/proxmox/vms?search=${encodeURIComponent(vm.vm_name)}`);
                                onClose();
                              }}
                              className="text-blue-500 dark:text-blue-400 hover:underline text-left"
                            >
                              {vm.vm_name}
                            </button>
                          </td>
                          <td className="px-3 py-2">
                            <span className={`inline-flex px-1.5 py-0.5 rounded-full text-[9px] font-bold ${
                              (vm.status || "").toLowerCase() === "running"
                                ? "bg-emerald-100 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-400"
                                : "bg-slate-100 dark:bg-slate-800 text-slate-500"
                            }`}>
                              {(vm.status || "stopped").toUpperCase()}
                            </span>
                          </td>
                          <td className="px-3 py-2 text-slate-500">{vm.os || "—"}</td>
                          <td className="px-3 py-2 text-slate-500 font-mono">
                            {vm.cpus || vm.cores || vm.vm_cpu}C / {vm.max_memory || vm.ram || vm.vm_max_mem}G / {vm.max_disk || vm.disk_size || vm.vm_max_disk}G
                          </td>
                          <td className="px-3 py-2">
                            <button
                              onClick={() => {
                                navigate(`/infrastructure/nodes?node=${encodeURIComponent(vm.node_name || vm.node)}`);
                                onClose();
                              }}
                              className="text-slate-500 dark:text-slate-400 hover:text-blue-500 hover:underline mr-1 font-mono"
                            >
                              {vm.node_name || vm.node}
                            </button>
                            /
                            <button
                              onClick={() => {
                                navigate(`/infrastructure/clusters?cluster=${encodeURIComponent(vm.cluster_name || vm.cluster)}`);
                                onClose();
                              }}
                              className="text-slate-500 dark:text-slate-400 hover:text-blue-500 hover:underline ml-1 font-mono"
                            >
                              {vm.cluster_name || vm.cluster || "Standalone"}
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </>
                )}

                {/* Node Table Header */}
                {type === "node" && (
                  <>
                    <thead className="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 uppercase tracking-wider font-bold">
                      <tr>
                        <th className="px-4 py-2.5">Node Name</th>
                        <th className="px-4 py-2.5">IP Address</th>
                        <th className="px-4 py-2.5">Status</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100 dark:divide-slate-800">
                      {filteredRecords.map((node, idx) => (
                        <tr key={node.node_name || idx} className="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                          <td className="px-4 py-2.5 font-bold">
                            <button
                              onClick={() => {
                                navigate(`/infrastructure/nodes?node=${encodeURIComponent(node.node_name)}`);
                                onClose();
                              }}
                              className="text-blue-500 dark:text-blue-400 hover:underline"
                            >
                              {node.node_name}
                            </button>
                          </td>
                          <td className="px-4 py-2.5 font-mono text-slate-500">{node.ip || "—"}</td>
                          <td className="px-4 py-2.5">
                            <span className={`px-2 py-0.5 rounded text-[10px] font-bold ${
                              node.live_status ? "bg-emerald-100 text-emerald-700" : "bg-red-100 text-red-700"
                            }`}>
                              {node.live_status ? "ONLINE" : "OFFLINE"}
                            </span>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </>
                )}

                {/* Cluster Table Header */}
                {type === "cluster" && (
                  <>
                    <thead className="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 uppercase tracking-wider font-bold">
                      <tr>
                        <th className="px-4 py-2.5">Cluster Name</th>
                        <th className="px-4 py-2.5">Status</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100 dark:divide-slate-800">
                      {filteredRecords.map((cluster, idx) => (
                        <tr key={cluster.cluster_name || idx} className="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                          <td className="px-4 py-2.5 font-bold">
                            <button
                              onClick={() => {
                                navigate(`/infrastructure/clusters?cluster=${encodeURIComponent(cluster.cluster_name)}`);
                                onClose();
                              }}
                              className="text-blue-500 dark:text-blue-400 hover:underline"
                            >
                              {cluster.cluster_name}
                            </button>
                          </td>
                          <td className="px-4 py-2.5">
                            <span className="px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-700">
                              ACTIVE
                            </span>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </>
                )}

                {/* Storage Table Header */}
                {type === "storage" && (
                  <>
                    <thead className="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 uppercase tracking-wider font-bold">
                      <tr>
                        <th className="px-3 py-2.5">Pool Name</th>
                        <th className="px-3 py-2.5">Node</th>
                        <th className="px-3 py-2.5">Type</th>
                        <th className="px-3 py-2.5">Status</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100 dark:divide-slate-800">
                      {filteredRecords.map((pool, idx) => (
                        <tr key={idx} className="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                          <td className="px-3 py-2 font-bold">
                            <button
                              onClick={() => {
                                navigate(`/infrastructure/storage?pool=${encodeURIComponent(pool.storage_name)}`);
                                onClose();
                              }}
                              className="text-blue-500 dark:text-blue-400 hover:underline"
                            >
                              {pool.storage_name}
                            </button>
                          </td>
                          <td className="px-3 py-2 font-mono text-slate-550">
                            <button
                              onClick={() => {
                                navigate(`/infrastructure/nodes?node=${encodeURIComponent(pool.node_name)}`);
                                onClose();
                              }}
                              className="hover:text-blue-500 hover:underline"
                            >
                              {pool.node_name}
                            </button>
                          </td>
                          <td className="px-3 py-2 text-slate-500 capitalize">{pool.storage_type || "—"}</td>
                          <td className="px-3 py-2">
                            <span className={`px-2 py-0.5 rounded text-[10px] font-bold ${
                              pool.live_status ? "bg-emerald-100 text-emerald-700" : "bg-red-100 text-red-700"
                            }`}>
                              {pool.live_status ? "ACTIVE" : "INACTIVE"}
                            </span>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </>
                )}

                {/* User Table Header */}
                {type === "user" && (
                  <>
                    <thead className="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 uppercase tracking-wider font-bold">
                      <tr>
                        <th className="px-4 py-2.5">Staff Code</th>
                        <th className="px-4 py-2.5">Name</th>
                        <th className="px-4 py-2.5">Entity/Division</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100 dark:divide-slate-800">
                      {filteredRecords.map((usr, idx) => (
                        <tr key={usr.staff_code || idx} className="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                          <td className="px-4 py-2.5 font-mono font-bold text-blue-500 dark:text-blue-400 select-all">
                            {usr.staff_code}
                          </td>
                          <td className="px-4 py-2.5 font-semibold text-slate-800 dark:text-slate-200">{usr.name || usr.username || "—"}</td>
                          <td className="px-4 py-2.5 text-slate-500">
                            {usr.entity || "—"} / {usr.division || "—"}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </>
                )}
              </table>
            </div>
          )}
        </div>
      </dMotion.div>

      {/* Export customize overlay */}
      {showPopup && (
        <ReportPopup
          availableColumns={ALL_REPORT_FIELDS}
          selectedColumns={selectedColumns}
          setSelectedColumns={setSelectedColumns}
          selectedFormat={selectedFormat}
          setSelectedFormat={setSelectedFormat}
          onClose={() => setShowPopup(false)}
          onDownload={handleExport}
        />
      )}
    </dAnimatePresence>
  );
}
