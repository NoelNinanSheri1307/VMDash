DROP TABLE IF EXISTS `vm_node_relation`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `vm_node_relation` (
  `uuid` varchar(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `cluster_name` varchar(15) COLLATE utf8mb4_unicode_ci NOT NULL,
  `node_name` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  `initial_at` datetime DEFAULT NULL,
  `updated_at` datetime DEFAULT NULL,
