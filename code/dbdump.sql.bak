CREATE DATABASE IF NOT EXISTS ccds_db;
USE ccds_db;

DROP TABLE IF EXISTS `empdetails`;
CREATE TABLE `empdetails` (
  `staff_code` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  `name` varchar(100) COLLATE utf8mb4_unicode_ci NOT NULL,
  `division` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  `groupname` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  `entity` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  PRIMARY KEY (`staff_code`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

DROP TABLE IF EXISTS `users`;
CREATE TABLE `users` (
  `staff_code` varchar(7) COLLATE utf8mb4_unicode_ci NOT NULL,
  `name` varchar(25) COLLATE utf8mb4_unicode_ci NOT NULL,
  `center` varchar(6) COLLATE utf8mb4_unicode_ci NOT NULL,
  `entity` varchar(5) COLLATE utf8mb4_unicode_ci NOT NULL,
  `groupname` varchar(5) COLLATE utf8mb4_unicode_ci NOT NULL,
  `division` varchar(5) COLLATE utf8mb4_unicode_ci NOT NULL,
  `section` varchar(5) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  PRIMARY KEY (`staff_code`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

DROP TABLE IF EXISTS `vms`;
CREATE TABLE `vms` (
  `vm_name` varchar(30) COLLATE utf8mb4_unicode_ci NOT NULL,
  `host_name` varchar(25) COLLATE utf8mb4_unicode_ci NOT NULL,
  `environment` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  `cluster` varchar(15) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `ram` int NOT NULL,
  `cores` int NOT NULL,
  `ip` varchar(15) COLLATE utf8mb4_unicode_ci NOT NULL,
  `mac` varchar(48) COLLATE utf8mb4_unicode_ci NOT NULL,
  `os` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  `disk_size` int NOT NULL,
  `source` varchar(5) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `narc` varchar(10) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `time_created` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL,
  `gpu` varchar(5) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  PRIMARY KEY (`vm_name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

DROP TABLE IF EXISTS `vm_users`;
CREATE TABLE `vm_users` (
  `vm_name` varchar(30) COLLATE utf8mb4_unicode_ci NOT NULL,
  `staff_code` varchar(7) COLLATE utf8mb4_unicode_ci NOT NULL,
  PRIMARY KEY (`vm_name`,`staff_code`),
  KEY `staff_code` (`staff_code`),
  CONSTRAINT `vm_users_ibfk_1` FOREIGN KEY (`vm_name`) REFERENCES `vms` (`vm_name`) ON DELETE CASCADE,
  CONSTRAINT `vm_users_ibfk_2` FOREIGN KEY (`staff_code`) REFERENCES `users` (`staff_code`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

DROP TABLE IF EXISTS `user_role`;
CREATE TABLE `user_role` (
  `staff_code1` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `role` enum('admin','manager','user') COLLATE utf8mb4_unicode_ci NOT NULL,
  `password_hash` varchar(255) COLLATE utf8mb4_unicode_ci NOT NULL,
  PRIMARY KEY (`staff_code1`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

