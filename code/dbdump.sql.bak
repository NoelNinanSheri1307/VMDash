DROP TABLE IF EXISTS `vm_storage_relation`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `vm_storage_relation` (
  `uuid` varchar(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `cluster_name` varchar(15) COLLATE utf8mb4_unicode_ci NOT NULL,
  `storage_name` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `node_name` varchar(15) COLLATE utf8mb4_unicode_ci NOT NULL,
  `vm_disk_image` varchar(50) COLLATE utf8mb4_unicode_ci NOT NULL,
  `size` varchar(10) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `initial_at` datetime DEFAULT NULL,
  `updated_at` datetime DEFAULT NULL,
  PRIMARY KEY (`uuid`,`cluster_name`,`storage_name`,`node_name`,`vm_disk_image`),
  KEY `cluster_name` (`cluster_name`,`storage_name`,`node_name`),
  CONSTRAINT `vm_storage_relation_ibfk_1` FOREIGN KEY (`cluster_name`, `storage_name`, `node_name`) REFERENCES `storage` (`cluster_name`, `storage_name`, `node_name`) ON DELETE CASCADE,
  CONSTRAINT `vm_storage_relation_ibfk_2` FOREIGN KEY (`uuid`) REFERENCES `vm` (`uuid`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

