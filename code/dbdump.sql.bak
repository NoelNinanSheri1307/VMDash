--
-- Table structure for table `vm_cluster_relation`
--

DROP TABLE IF EXISTS `vm_cluster_relation`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `vm_cluster_relation` (
  `uuid` varchar(36) COLLATE utf8mb4_unicode_ci NOT NULL,
  `cluster_name` varchar(15) COLLATE utf8mb4_unicode_ci NOT NULL,
  `initial_at` datetime DEFAULT NULL,
  `updated_at` datetime DEFAULT NULL,
  PRIMARY KEY (`uuid`,`cluster_name`),
  KEY `cluster_name` (`cluster_name`),
  CONSTRAINT `vm_cluster_relation_ibfk_1` FOREIGN KEY (`uuid`) REFERENCES `vm` (`uuid`) ON DELETE CASCADE,
  CONSTRAINT `vm_cluster_relation_ibfk_2` FOREIGN KEY (`cluster_name`) REFERENCES `cluster` (`cluster_name`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

